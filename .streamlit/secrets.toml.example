# Copy this file to secrets.toml (locally) or paste into
# Streamlit Cloud > App settings > Secrets.
# Do NOT commit the actual secrets.toml file.

[snowflake]
account = "db70409.europe-west3.gcp"
user = "YOUR_USER"
password = "YOUR_PASSWORD"
warehouse = "QUERY_RUNNER_XSMALL"
database = "DWH_PROD_TRANSFORM"
schema = "TR_LEVEL_0_ARCOS"
role = "DWH_PROD_TRANSFORM_READER"
