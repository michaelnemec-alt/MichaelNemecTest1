# Copy to `.env` (next to docker-compose.yml) and fill in.
# The .env file is git-ignored — never commit real tokens.

CUBEANALYTICS_TOKEN=your_cubeanalytics_api_token

# Optional — only for the Snowflake-backed pages. Leave blank to disable them.
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
